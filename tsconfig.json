{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "es2016",
    "module": "es2020",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "allowJs": true,
    "outDir": "./dist",
    "removeComments": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "typeRoots": ["./types"],
    "types": ["acode-plugin-types"],
    "skipLibCheck": true,
    "lib": ["ES2017"],
    "paths": {
        "@/linters/*": ["./src/ace-linters/src/*"]
    }
  },
  "exclude": ["./dist/**/*"],
}
